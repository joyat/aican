<Window x:Class="AiCan.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AiCan Desktop"
        Width="1320"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="20">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="370" />
      <ColumnDefinition Width="24" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Padding="24"
            CornerRadius="28"
            Background="White">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <Border Padding="22"
                  CornerRadius="24"
                  Background="{StaticResource AiCanRoseBrush}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Width="58"
                      Height="58"
                      VerticalAlignment="Top"
                      Background="{StaticResource AiCanTealBrush}"
                      CornerRadius="29">
                <TextBlock x:Name="BotInitialsTextBlock"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Text="RB" />
              </Border>
              <StackPanel Grid.Column="1" Margin="16,0,0,0">
                <TextBlock Text="Personal Office Bot"
                           FontSize="13"
                           Foreground="{StaticResource AiCanSlateBrush}" />
                <TextBlock x:Name="BotDisplayNameTextBlock"
                           Margin="0,4,0,0"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Text="RafiBot" />
                <TextBlock x:Name="BotMoodTextBlock"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AiCanSlateBrush}"
                           Text="Warm, grounded, and ready to help with the workday." />
              </StackPanel>
            </Grid>
          </Border>

          <Border Margin="0,18,0,0"
                  Padding="18"
                  CornerRadius="22"
                  Background="{StaticResource AiCanCloudBrush}">
            <StackPanel>
              <TextBlock Text="Workspace Connection"
                         FontSize="18"
                         FontWeight="SemiBold" />
              <TextBlock Margin="0,4,0,0"
                         Foreground="{StaticResource AiCanSlateBrush}"
                         Text="Use the direct bot connection for the demo. Microsoft 365 sign-in stays optional until a real Entra app is configured." />

              <TextBlock Margin="0,18,0,0" Text="Server URL" />
              <TextBox x:Name="ServerUrlTextBox" />

              <TextBlock Text="Email" />
              <TextBox x:Name="EmailTextBox" />

              <TextBlock Text="Display Name" />
              <TextBox x:Name="DisplayNameTextBox" />

              <TextBlock Text="Department" />
              <TextBox x:Name="DepartmentTextBox" />

              <WrapPanel Margin="0,6,0,0">
                <Button x:Name="ConnectButton"
                        Width="150"
                        Content="Connect Bot"
                        Click="ConnectButton_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button x:Name="M365Button"
                        Width="150"
                        Content="Use Microsoft 365"
                        Click="M365Button_Click"
                        Style="{StaticResource SecondaryButtonStyle}" />
              </WrapPanel>
            </StackPanel>
          </Border>

          <Border Margin="0,18,0,0"
                  Padding="18"
                  CornerRadius="22"
                  Background="White"
                  BorderBrush="#E4EAF2"
                  BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Bot Personality"
                         FontSize="18"
                         FontWeight="SemiBold" />

              <TextBlock Margin="0,18,0,0" Text="Bot Name" />
              <TextBox x:Name="BotNameTextBox" />

              <TextBlock Text="Tone" />
              <ComboBox x:Name="ToneComboBox" SelectedIndex="0">
                <ComboBoxItem Content="WarmProfessional" />
                <ComboBoxItem Content="DirectConcise" />
                <ComboBoxItem Content="FormalBusiness" />
              </ComboBox>

              <TextBlock Text="Work Style" />
              <ComboBox x:Name="WorkStyleComboBox" SelectedIndex="0">
                <ComboBoxItem Content="HelpfulAndConcise" />
                <ComboBoxItem Content="DetailedGuidance" />
                <ComboBoxItem Content="TaskDriven" />
              </ComboBox>

              <TextBlock Text="Preferred Language" />
              <TextBox x:Name="LanguageTextBox" />

              <Button Width="145"
                      Content="Save Personality"
                      Click="SaveProfileButton_Click"
                      Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
          </Border>

          <Border Margin="0,18,0,0"
                  Padding="18"
                  CornerRadius="22"
                  Background="{StaticResource AiCanMintBrush}">
            <StackPanel>
              <TextBlock Text="Document Intake"
                         FontSize="18"
                         FontWeight="SemiBold" />
              <TextBlock Margin="0,4,0,0"
                         Foreground="{StaticResource AiCanSlateBrush}"
                         Text="Use manual upload for demos or keep a watched folder running for lightweight intake automation." />

              <TextBlock Margin="0,18,0,0" Text="Watched Folder" />
              <TextBox x:Name="WatchedFolderTextBox" />

              <WrapPanel Margin="0,6,0,0">
                <Button Width="130"
                        Content="Upload File"
                        Click="UploadFileButton_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Width="150"
                        Content="Start Watcher"
                        Click="WatchFolderButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}" />
              </WrapPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Column="2"
            Padding="24"
            CornerRadius="30"
            Background="{StaticResource AiCanInkBrush}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock Foreground="#D5E1F0"
                       FontSize="13"
                       Text="Employee Workspace Assistant" />
            <TextBlock x:Name="ConversationTitleTextBlock"
                       Margin="0,6,0,0"
                       FontSize="30"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="Talk to RafiBot" />
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,10,0,0"
                       Foreground="#B5C7DE"
                       TextWrapping="Wrap"
                       Text="Connect the bot to begin." />
          </StackPanel>

          <Border Grid.Column="1"
                  Padding="14,10"
                  Background="#1E3358"
                  CornerRadius="18"
                  VerticalAlignment="Top">
            <StackPanel>
              <TextBlock Text="Demo Users"
                         Foreground="#D5E1F0"
                         FontSize="12" />
              <TextBlock Margin="0,6,0,0"
                         Foreground="White"
                         Text="admin@aican.com&#x0a;docadmin@aican.com&#x0a;user@aican.com" />
            </StackPanel>
          </Border>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,20,0,0"
                Padding="16"
                Background="#162A47"
                CornerRadius="22">
          <StackPanel>
            <TextBlock Foreground="#D5E1F0"
                       FontSize="13"
                       Text="Helpful starters" />
            <WrapPanel Margin="0,12,0,0">
              <Button Content="When did we last purchase a printer?"
                      Tag="When did we last purchase a printer?"
                      Click="PromptButton_Click"
                      Style="{StaticResource PromptButtonStyle}" />
              <Button Content="Show me the latest shared finance invoice."
                      Tag="Show me the latest shared finance invoice."
                      Click="PromptButton_Click"
                      Style="{StaticResource PromptButtonStyle}" />
              <Button Content="What files can I access in Finance?"
                      Tag="What files can I access in Finance?"
                      Click="PromptButton_Click"
                      Style="{StaticResource PromptButtonStyle}" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,20,0,0"
                Padding="8"
                Background="#10203A"
                CornerRadius="28">
          <ListBox x:Name="MessagesListBox"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Focusable" Value="False" />
              </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="10,10,10,4"
                            HorizontalAlignment="{Binding Alignment}">
                  <TextBlock Margin="6,0,6,6"
                             Foreground="{Binding MetaBrush}"
                             FontSize="12"
                             Text="{Binding Meta}" />
                  <Border MaxWidth="720"
                          Padding="16,14"
                          Background="{Binding BubbleBrush}"
                          BorderBrush="{Binding BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="22">
                    <StackPanel>
                      <TextBlock FontWeight="SemiBold"
                                 Foreground="{Binding HeaderBrush}"
                                 Text="{Binding Speaker}" />
                      <TextBlock Margin="0,8,0,0"
                                 TextWrapping="Wrap"
                                 Foreground="{Binding TextBrush}"
                                 Text="{Binding Text}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>

        <Border Grid.Row="3"
                Margin="0,22,0,0"
                Padding="14"
                Background="#162A47"
                CornerRadius="26">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="MessageTextBox"
                     Margin="0"
                     MinHeight="84"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" />
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    Content="Send"
                    Click="SendButton_Click"
                    Style="{StaticResource PrimaryButtonStyle}" />
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
