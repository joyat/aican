<Window x:Class="AiCan.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AiCan Desktop"
        Width="1160"
        Height="760"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="20">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="360" />
      <ColumnDefinition Width="20" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0">
      <TextBlock Text="Assistant Onboarding" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

      <TextBlock Text="Server URL" />
      <TextBox x:Name="ServerUrlTextBox" Text="http://localhost:5000" Margin="0,4,0,12" />

      <TextBlock Text="Office 365 Email" />
      <TextBox x:Name="EmailTextBox" Margin="0,4,0,12" />

      <TextBlock Text="Display Name" />
      <TextBox x:Name="DisplayNameTextBox" Margin="0,4,0,12" />

      <TextBlock Text="Bot Name" />
      <TextBox x:Name="BotNameTextBox" Margin="0,4,0,12" />

      <TextBlock Text="Department" />
      <TextBox x:Name="DepartmentTextBox" Margin="0,4,0,12" />

      <TextBlock Text="Tone" />
      <ComboBox x:Name="ToneComboBox" SelectedIndex="0" Margin="0,4,0,12">
        <ComboBoxItem Content="WarmProfessional" />
        <ComboBoxItem Content="DirectConcise" />
        <ComboBoxItem Content="FormalBusiness" />
      </ComboBox>

      <TextBlock Text="Work Style" />
      <ComboBox x:Name="WorkStyleComboBox" SelectedIndex="0" Margin="0,4,0,12">
        <ComboBoxItem Content="HelpfulAndConcise" />
        <ComboBoxItem Content="DetailedGuidance" />
        <ComboBoxItem Content="TaskDriven" />
      </ComboBox>

      <TextBlock Text="Preferred Language" />
      <TextBox x:Name="LanguageTextBox" Text="en" Margin="0,4,0,12" />

      <TextBlock Text="Watched Folder" />
      <TextBox x:Name="WatchedFolderTextBox" Margin="0,4,0,12" />

      <WrapPanel Margin="0,8,0,0">
        <Button x:Name="SignInButton" Content="Sign In" Width="120" Margin="0,0,8,0" Click="SignInButton_Click" />
        <Button x:Name="SaveProfileButton" Content="Save Profile" Width="120" Margin="0,0,8,0" Click="SaveProfileButton_Click" />
        <Button x:Name="WatchFolderButton" Content="Start Watcher" Width="120" Click="WatchFolderButton_Click" />
      </WrapPanel>

      <TextBlock x:Name="StatusTextBlock" Margin="0,16,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="110" />
      </Grid.RowDefinitions>

      <ListBox x:Name="MessagesListBox" Grid.Row="0" />

      <Grid Grid.Row="1" Margin="0,16,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="MessageTextBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
        <Button Grid.Column="1" Content="Send" Margin="16,0,0,0" Click="SendButton_Click" />
      </Grid>
    </Grid>
  </Grid>
</Window>
