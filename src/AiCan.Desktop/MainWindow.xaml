<Window x:Class="AiCan.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AiCan"
        Icon="Assets/AiCan-mascot.png"
        Width="1340"
        Height="880"
        MinWidth="1200"
        MinHeight="780"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="14">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="320" />
      <ColumnDefinition Width="14" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            CornerRadius="24"
            Background="{StaticResource AiCanGlassBrush}"
            BorderBrush="#80FFFFFF"
            BorderThickness="1"
            Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Border CornerRadius="20"
                  Padding="12"
                  Background="#F6FCFE"
                  BorderBrush="#BDE2F2"
                  BorderThickness="1">
            <StackPanel>
              <Image Source="Assets/AiCan-wordmark.png"
                     Height="58"
                     HorizontalAlignment="Left"
                     Stretch="Uniform" />
              <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="44" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="38"
                        Height="38"
                        CornerRadius="19"
                        Background="#173E76">
                  <TextBlock x:Name="BotInitialsTextBlock"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="16"
                             FontWeight="Bold"
                             Foreground="White"
                             Text="JB" />
                </Border>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                  <TextBlock FontSize="10"
                             Text="Your personal assistant"
                             Foreground="{StaticResource AiCanSlateBrush}" />
                  <TextBlock x:Name="BotDisplayNameTextBlock"
                             Margin="0,2,0,0"
                             FontSize="21"
                             FontWeight="SemiBold"
                             Text="JoBot" />
                  <TextBlock x:Name="BotMoodTextBlock"
                             Margin="0,3,0,0"
                             FontSize="11"
                             TextWrapping="Wrap"
                             Foreground="{StaticResource AiCanSlateBrush}"
                             Text="Warm, polished, and grounded in your office context." />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border Grid.Row="1"
                  Margin="0,8,0,0"
                  CornerRadius="18"
                  Padding="12"
                  Background="#F7FBFF"
                  BorderBrush="#CFE0F3"
                  BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Connection"
                         FontSize="15"
                         FontWeight="SemiBold" />

              <TextBlock Margin="0,6,0,0" FontSize="11" Text="Server URL" />
              <TextBox x:Name="ServerUrlTextBox" />

              <TextBlock Margin="0,4,0,0" FontSize="11" Text="Email" />
              <TextBox x:Name="EmailTextBox" />

              <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="8" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock FontSize="11" Text="Display Name" />
                  <TextBox x:Name="DisplayNameTextBox" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock FontSize="11" Text="Bot Name" />
                  <TextBox x:Name="BotNameTextBox" />
                </StackPanel>
              </Grid>

              <TextBlock Margin="0,4,0,0" FontSize="11" Text="Department" />
              <TextBox x:Name="DepartmentTextBox" />

              <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="8" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="ConnectButton"
                        Grid.Column="0"
                        Height="36"
                        Content="Connect Bot"
                        Click="ConnectButton_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button x:Name="M365Button"
                        Grid.Column="2"
                        Height="36"
                        Content="Use Microsoft 365"
                        Click="M365Button_Click"
                        Style="{StaticResource SecondaryButtonStyle}" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Grid.Row="2"
                  Margin="0,8,0,0"
                  CornerRadius="18"
                  Padding="12"
                  Background="{StaticResource AiCanMintBrush}">
            <StackPanel>
              <TextBlock Text="Document Intake"
                         FontSize="15"
                         FontWeight="SemiBold" />

              <TextBlock Margin="0,6,0,0" FontSize="11" Text="Watched Folder" />
              <TextBox x:Name="WatchedFolderTextBox" />

              <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="8" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Height="36"
                        Content="Upload File"
                        Click="UploadFileButton_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Grid.Column="2"
                        Height="36"
                        Content="Start Watcher"
                        Click="WatchFolderButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Grid.Row="3"
                  Margin="0,8,0,0"
                  CornerRadius="18"
                  Padding="12"
                  Background="#F8FBFF"
                  BorderBrush="#D7E5F3"
                  BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Accounts"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource AiCanSlateBrush}" />
              <WrapPanel Margin="0,6,0,0">
                <TextBlock Margin="0,0,12,0"
                           FontSize="11"
                           Foreground="{StaticResource AiCanSlateBrush}"
                           Text="admin@aican.com" />
                <TextBlock Margin="0,0,12,0"
                           FontSize="11"
                           Foreground="{StaticResource AiCanSlateBrush}"
                           Text="docadmin@aican.com" />
                <TextBlock FontSize="11"
                           Foreground="{StaticResource AiCanSlateBrush}"
                           Text="user@aican.com" />
              </WrapPanel>
            </StackPanel>
          </Border>
        </Grid>
      </ScrollViewer>
    </Border>

    <Border Grid.Column="2"
            CornerRadius="34"
            Padding="20"
            Background="{StaticResource AiCanNavyGlassBrush}"
            BorderBrush="#4A688F"
            BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Background="#10233F"
                BorderBrush="#34537E"
                BorderThickness="1"
                CornerRadius="30">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel>
                <TextBlock Foreground="#CBDCF0"
                           FontSize="13"
                           Text="AiCan workspace" />
                <TextBlock x:Name="ConversationTitleTextBlock"
                           Margin="0,6,0,0"
                           FontSize="31"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="Talk to JoBot" />
                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,10,0,0"
                           Foreground="#B8CAE2"
                           TextWrapping="Wrap"
                           Text="Connect the bot to begin." />
              </StackPanel>

              <Border Grid.Column="1"
                      Padding="14,10"
                      Background="#173056"
                      BorderBrush="#3D618E"
                      BorderThickness="1"
                      CornerRadius="20"
                      VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Ellipse x:Name="StatusLedEllipse"
                           Width="12"
                           Height="12"
                           Margin="0,0,10,0"
                           Fill="#7B8798" />
                  <TextBlock x:Name="StatusWordTextBlock"
                             Foreground="White"
                             FontWeight="SemiBold"
                             Text="OFFLINE" />
                </StackPanel>
              </Border>
            </Grid>

            <ListBox Grid.Row="1"
                     x:Name="MessagesListBox"
                     Margin="0,18,0,0"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                  <Setter Property="BorderThickness" Value="0" />
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                  <Setter Property="Background" Value="Transparent" />
                  <Setter Property="Focusable" Value="False" />
                </Style>
              </ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="8,8,8,4"
                              HorizontalAlignment="{Binding Alignment}">
                    <TextBlock Margin="6,0,6,6"
                               Foreground="{Binding MetaBrush}"
                               FontSize="12"
                               Text="{Binding Meta}" />
                    <Border MaxWidth="720"
                            Padding="16,14"
                            Background="{Binding BubbleBrush}"
                            BorderBrush="{Binding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="24">
                      <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{Binding HeaderBrush}"
                                   Text="{Binding Speaker}" />
                        <TextBlock Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding TextBrush}"
                                   Text="{Binding Text}" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="#173056"
                    BorderBrush="#3E618C"
                    BorderThickness="1"
                    CornerRadius="22">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="132" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="MessageTextBox"
                         Margin="0"
                         MinHeight="74"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" />
                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Margin="14,0,0,0"
                        Content="Send"
                        Click="SendButton_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="12,8"
                Background="#173056"
                BorderBrush="#3B5E87"
                BorderThickness="1"
                CornerRadius="18">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       Foreground="#DCE8F6"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Text="Personality" />

            <WrapPanel Grid.Column="1"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center">
              <RadioButton x:Name="ToneWarmRadio"
                           GroupName="ToneGroup"
                           Content="Warm"
                           IsChecked="True"
                           Checked="RibbonChanged"
                           Style="{StaticResource RibbonRadioStyle}" />
              <RadioButton x:Name="ToneFormalRadio"
                           GroupName="ToneGroup"
                           Content="Formal"
                           Checked="RibbonChanged"
                           Style="{StaticResource RibbonRadioStyle}" />
              <RadioButton x:Name="LanguageEnglishRadio"
                           GroupName="LanguageGroup"
                           Content="EN"
                           IsChecked="True"
                           Checked="RibbonChanged"
                           Style="{StaticResource RibbonRadioStyle}" />
              <RadioButton x:Name="LanguageBanglaRadio"
                           GroupName="LanguageGroup"
                           Content="BN"
                           Checked="RibbonChanged"
                           Style="{StaticResource RibbonRadioStyle}" />
            </WrapPanel>

            <Button x:Name="SaveRibbonButton"
                    Grid.Column="2"
                    Width="110"
                    Height="34"
                    Margin="12,0,0,0"
                    Content="Apply"
                    Click="SaveProfileButton_Click"
                    Style="{StaticResource SecondaryButtonStyle}" />
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
