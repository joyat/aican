<Application x:Class="AiCan.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <Color x:Key="AiCanInkColor">#052D55</Color>
    <Color x:Key="AiCanSlateColor">#4B6991</Color>
    <Color x:Key="AiCanCloudColor">#F3FAFD</Color>
    <Color x:Key="AiCanMintColor">#DDF5FB</Color>
    <Color x:Key="AiCanGoldColor">#63C8E6</Color>
    <Color x:Key="AiCanTealColor">#1FA9DA</Color>
    <Color x:Key="AiCanRoseColor">#E8F7FC</Color>
    <Color x:Key="AiCanGlassColor">#D4F8FDFF</Color>
    <Color x:Key="AiCanNavyGlassColor">#C0104A72</Color>

    <SolidColorBrush x:Key="AiCanInkBrush" Color="{StaticResource AiCanInkColor}" />
    <SolidColorBrush x:Key="AiCanSlateBrush" Color="{StaticResource AiCanSlateColor}" />
    <SolidColorBrush x:Key="AiCanCloudBrush" Color="{StaticResource AiCanCloudColor}" />
    <SolidColorBrush x:Key="AiCanMintBrush" Color="{StaticResource AiCanMintColor}" />
    <SolidColorBrush x:Key="AiCanGoldBrush" Color="{StaticResource AiCanGoldColor}" />
    <SolidColorBrush x:Key="AiCanTealBrush" Color="{StaticResource AiCanTealColor}" />
    <SolidColorBrush x:Key="AiCanRoseBrush" Color="{StaticResource AiCanRoseColor}" />
    <SolidColorBrush x:Key="AiCanGlassBrush" Color="{StaticResource AiCanGlassColor}" />
    <SolidColorBrush x:Key="AiCanNavyGlassBrush" Color="{StaticResource AiCanNavyGlassColor}" />

    <Style TargetType="Window">
      <Setter Property="FontFamily" Value="Bahnschrift" />
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F5FBFE" Offset="0" />
            <GradientStop Color="#DDF2FA" Offset="0.46" />
            <GradientStop Color="#C8E6F5" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
      <Setter Property="Foreground" Value="{StaticResource AiCanInkBrush}" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#F9FBFE" />
      <Setter Property="Foreground" Value="{StaticResource AiCanInkBrush}" />
      <Setter Property="BorderBrush" Value="#C7DDF0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Margin" Value="0,4,0,8" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource AiCanTealBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource AiCanTealBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="14,9" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource AiCanInkBrush}" />
      <Setter Property="BorderBrush" Value="#D9E2EE" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PromptButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Background" Value="#1C355E" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#375C91" />
    </Style>

    <Style x:Key="RibbonRadioStyle" TargetType="RadioButton">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Chip"
                    Padding="12,6"
                    Background="#16355F"
                    BorderBrush="#4572A0"
                    BorderThickness="1"
                    CornerRadius="14">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Chip" Property="Background" Value="#66DAF7" />
                <Setter TargetName="Chip" Property="BorderBrush" Value="#1EB8E8" />
                <Setter Property="Foreground" Value="#0C2558" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chip" Property="BorderBrush" Value="#9BE7FF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Application.Resources>
</Application>
