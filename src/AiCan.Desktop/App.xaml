<Application x:Class="AiCan.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <Color x:Key="AiCanInkColor">#14213D</Color>
    <Color x:Key="AiCanSlateColor">#4B5D7A</Color>
    <Color x:Key="AiCanCloudColor">#F4F7FB</Color>
    <Color x:Key="AiCanMintColor">#D8F3E6</Color>
    <Color x:Key="AiCanGoldColor">#F5C451</Color>
    <Color x:Key="AiCanTealColor">#2C7A7B</Color>
    <Color x:Key="AiCanRoseColor">#FFF1E8</Color>

    <SolidColorBrush x:Key="AiCanInkBrush" Color="{StaticResource AiCanInkColor}" />
    <SolidColorBrush x:Key="AiCanSlateBrush" Color="{StaticResource AiCanSlateColor}" />
    <SolidColorBrush x:Key="AiCanCloudBrush" Color="{StaticResource AiCanCloudColor}" />
    <SolidColorBrush x:Key="AiCanMintBrush" Color="{StaticResource AiCanMintColor}" />
    <SolidColorBrush x:Key="AiCanGoldBrush" Color="{StaticResource AiCanGoldColor}" />
    <SolidColorBrush x:Key="AiCanTealBrush" Color="{StaticResource AiCanTealColor}" />
    <SolidColorBrush x:Key="AiCanRoseBrush" Color="{StaticResource AiCanRoseColor}" />

    <Style TargetType="Window">
      <Setter Property="FontFamily" Value="Bahnschrift" />
      <Setter Property="Background" Value="{StaticResource AiCanCloudBrush}" />
      <Setter Property="Foreground" Value="{StaticResource AiCanInkBrush}" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource AiCanInkBrush}" />
      <Setter Property="BorderBrush" Value="#D9E2EE" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,6,0,12" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource AiCanInkBrush}" />
      <Setter Property="BorderBrush" Value="#D9E2EE" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Margin" Value="0,6,0,12" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource AiCanTealBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource AiCanTealBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Margin" Value="0,0,10,10" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource AiCanInkBrush}" />
      <Setter Property="BorderBrush" Value="#D9E2EE" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PromptButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Background" Value="#FFFDF8" />
      <Setter Property="BorderBrush" Value="#E6DCC4" />
    </Style>
  </Application.Resources>
</Application>
