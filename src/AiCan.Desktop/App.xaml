<Application x:Class="AiCan.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>

    <!-- ═══════════  Palette from logo  ═══════════
         Ai  = bright cyan  #29C4E9
         Can = deep navy    #0B2260
         robot body = glassy #85D0EF → #3BADD4
    -->
    <SolidColorBrush x:Key="AiCanInkBrush"      Color="#E6F3FC" />
    <SolidColorBrush x:Key="AiCanSlateBrush"    Color="#4A7BA8" />
    <SolidColorBrush x:Key="AiCanCyanBrush"     Color="#29C4E9" />
    <SolidColorBrush x:Key="AiCanNavyBrush"     Color="#0B2260" />
    <SolidColorBrush x:Key="AiCanGlassBrush"    Color="#12FFFFFF" />
    <SolidColorBrush x:Key="AiCanMintBrush"     Color="#D6F4F9" />

    <!-- ═══════════  Window  ═══════════ -->
    <Style TargetType="Window">
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="Foreground" Value="#E6F3FC" />
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#040D1C" Offset="0" />
            <GradientStop Color="#071830" Offset="0.5" />
            <GradientStop Color="#05111F" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════  TextBox  ═══════════ -->
    <Style TargetType="TextBox">
      <Setter Property="Background"        Value="#0DFFFFFF" />
      <Setter Property="Foreground"        Value="#CCDFF5" />
      <Setter Property="CaretBrush"        Value="#29C4E9" />
      <Setter Property="BorderBrush"       Value="#1A3A5C" />
      <Setter Property="BorderThickness"   Value="1" />
      <Setter Property="Padding"           Value="9,6" />
      <Setter Property="Margin"            Value="0,2,0,5" />
      <Setter Property="FontSize"          Value="12" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ScrollViewer x:Name="PART_ContentHost" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="#29C4E9" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════  Primary button — logo cyan  ═══════════ -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Foreground"      Value="#030E1E" />
      <Setter Property="FontWeight"      Value="SemiBold" />
      <Setter Property="FontSize"        Value="12" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding"         Value="14,8" />
      <Setter Property="Cursor"          Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" CornerRadius="10" Padding="{TemplateBinding Padding}">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#3DD4F5" Offset="0" />
                  <GradientStop Color="#17A8CC" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <Border.Effect>
                <DropShadowEffect Color="#29C4E9" BlurRadius="12" ShadowDepth="0" Opacity="0.5" />
              </Border.Effect>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.72" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.3" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════  Secondary button — glass outline  ═══════════ -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
      <Setter Property="Foreground"      Value="#7AB8D8" />
      <Setter Property="FontSize"        Value="11" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding"         Value="12,7" />
      <Setter Property="Cursor"          Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="#10FFFFFF"
                    BorderBrush="#1E4568"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="9"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF" />
                <Setter TargetName="Bd" Property="BorderBrush" Value="#29C4E9" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════  Personality chips  ═══════════ -->
    <Style x:Key="RibbonRadioStyle" TargetType="RadioButton">
      <Setter Property="Foreground" Value="#5B88B8" />
      <Setter Property="Margin"     Value="0,0,6,0" />
      <Setter Property="FontSize"   Value="11" />
      <Setter Property="Cursor"     Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Chip"
                    Padding="11,5"
                    Background="#0AFFFFFF"
                    BorderBrush="#162E4C"
                    BorderThickness="1"
                    CornerRadius="12">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Chip" Property="Background" Value="#CC29C4E9" />
                <Setter TargetName="Chip" Property="BorderBrush" Value="#29C4E9" />
                <Setter Property="Foreground" Value="#04111F" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chip" Property="BorderBrush" Value="#3BADD4" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Application.Resources>
</Application>
